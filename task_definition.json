[
    {
        "name": "my-task",
        "image": "nginx:latest",
        "cpu": 256,
        "memory": 512,
        "portMappings": [
            {
                "containerPort": 80,
                "hostPort": 80
            }
        ],
        "logLogGroup": {
          "Type": "AWS::Logs::LogGroup",
          "Properties": {
            "LogGroupName": "/ecs/my-task",
            "awslogs-region": "us-east-1",
            "RetentionInDays": ""
          }
        }   
    }
]

